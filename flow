def ensure_versioned_git_hooks() -> None:
    hooks_path = ROOT / "scripts" / "git-hooks"
    if not hooks_path.is_dir():
        return

    rc, _, _ = git_output(["git", "-C", str(ROOT), "rev-parse", "--is-inside-work-tree"])
    if rc != 0:
        return

    desired = "scripts/git-hooks"
    current_rc, current_stdout, _ = git_output(["git", "-C", str(ROOT), "config", "--local", "--get", "core.hooksPath"])
    if current_rc == 0 and current_stdout.strip() == desired:
        return

    set_rc, _, set_stderr = git_output(["git", "-C", str(ROOT), "config", "--local", "core.hooksPath", desired])
    if set_rc != 0:
        warning = set_stderr.strip() or "git config failed"
        print(f"Warning: no pude configurar core.hooksPath={desired}: {warning}")
        return

    print(f"Configured git hooks path: {desired}")


def command_init(args: argparse.Namespace) -> int:
    ensure_versioned_git_hooks()

    if not args.skip_doctor:
        doctor_rc = command_doctor(argparse.Namespace(json=False))
        if doctor_rc != 0:
            return doctor_rc

    env_rc = ensure_devcontainer_env(force=bool(args.force_secrets_sync))
    if env_rc != 0:
        return env_rc

    if args.skip_stack:
        return 0

    up_rc = command_stack_up(argparse.Namespace(build=bool(args.build)))
    if up_rc != 0:
        return up_rc

    stack_doctor_rc = command_stack_doctor(argparse.Namespace())
    if stack_doctor_rc != 0:
        return stack_doctor_rc

    ps_rc = command_stack_ps(argparse.Namespace())
    if ps_rc != 0:
        return ps_rc

    workflow_doctor_rc = command_workflow_doctor(argparse.Namespace(json=False))
    if workflow_doctor_rc != 0:
        return workflow_doctor_rc

    connection = gateway_connection()
    if connection.get("mode") == "remote" and connection.get("base_url"):
        print(f"Gateway remote target: {connection['base_url']}/healthz")
    else:
        print(f"Gateway host health: http://127.0.0.1:{gateway_host_port()}/healthz")
    return 0


