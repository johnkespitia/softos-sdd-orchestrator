def repo_compose_service(repo: str) -> str:
    config = repo_config(repo)
    explicit = str(config.get("compose_service", "")).strip()
    if explicit:
        return explicit
    path = str(config.get("path", ".")).strip().strip("/")
    if path and path != ".":
        return Path(path).name
    return repo


def workspace_host_root() -> Path:
    resolved_root = ROOT.resolve()
    parts = list(resolved_root.parts)
    if ".worktrees" in parts:
        index = parts.index(".worktrees")
        return Path(*parts[:index])
    return HOST_ROOT_HINT


def repo_container_workdir(repo_path: Path) -> Optional[str]:
    workspace_root = WORKSPACE_PATH.rstrip("/")
    resolved_repo = repo_path.resolve()
    repo_text = resolved_repo.as_posix()
    if repo_text == workspace_root or repo_text.startswith(f"{workspace_root}/"):
        return repo_text

    for candidate_root in [workspace_host_root().resolve(), HOST_ROOT_HINT.resolve()]:
        try:
            relative = resolved_repo.relative_to(candidate_root)
            return f"{workspace_root}/{relative.as_posix()}"
        except ValueError:
            continue
    return None


def root_container_workdir() -> str:
    return repo_container_workdir(ROOT) or WORKSPACE_PATH


def runtime_path(path: Path) -> Path:
    if running_inside_workspace():
        mapped = repo_container_workdir(path)
        if mapped:
            return Path(mapped)
    return path


def wrap_repo_command_for_service(repo: str, repo_path: Path, command: list[str]) -> list[str]:
    if os.environ.get("FLOW_SKIP_COMPOSE_WRAP") == "1" or os.environ.get("GITHUB_ACTIONS", "").lower() == "true":
        return command

    service_name = repo_compose_service(repo)
    if not service_name:
        return command

    workdir = repo_container_workdir(repo_path)
    if not workdir:
        return command

    return [
        *compose_base_command(),
        *compose_exec_args(service_name, interactive=False, workdir=workdir),
        *command,
    ]


