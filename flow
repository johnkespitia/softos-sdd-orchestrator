    if not force and all(target_path.is_file() for _, target_path in targets):
        return 0

    target_names = [target_name for target_name, _ in targets]
    action = "Regenerando" if force else "Materializando"
    print(f"{action} `.devcontainer/.env.generated` para el stack del workspace.")
    return flow_command_secrets_sync(
        argparse.Namespace(target=target_names, dry_run=False, json=False),
