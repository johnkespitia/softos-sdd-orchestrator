def devcontainer_env_targets() -> list[tuple[str, Path]]:
    payload = load_secrets_config()
    targets = secrets_target_entries(payload)
    matched: list[tuple[str, Path]] = []

    if "devcontainer_env" in targets:
        return [("devcontainer_env", secrets_target_path(targets["devcontainer_env"]))]

    for target_name, raw_target in targets.items():
        target_path = secrets_target_path(raw_target)
        try:
            relative_path = target_path.resolve().relative_to(ROOT.resolve())
        except ValueError:
            continue
        if relative_path == Path(".devcontainer/.env.generated"):
            matched.append((target_name, target_path))
    return matched


def ensure_devcontainer_env(*, force: bool = False) -> int:
    targets = devcontainer_env_targets()
