def configured_repo_ci_commands(repo: str) -> list[tuple[str, list[str]]]:
    config = repo_config(repo).get("ci")
    if not isinstance(config, dict):
        return []

    commands: list[tuple[str, list[str]]] = []
    for step, label in [("install", "Install"), ("lint", "Lint"), ("test", "Tests"), ("build", "Build")]:
        raw_command = config.get(step)
        if not isinstance(raw_command, list) or not all(isinstance(part, str) for part in raw_command):
            continue
        command = [part for part in raw_command if part]
        if command:
            commands.append((label, command))
    return commands


def repo_ci_commands(repo: str, repo_path: Path, skip_install: bool) -> list[tuple[str, list[str]]]:
    runner = str(repo_config(repo).get("test_runner", "none")).strip().lower()

    if repo == ROOT_REPO:
        return []

    configured = configured_repo_ci_commands(repo)
    if configured:
        if skip_install:
            configured = [item for item in configured if item[0] != "Install"]
        return [(label, wrap_repo_command_for_service(repo, repo_path, command)) for label, command in configured]

    if runner == "none":
        return []

    if runner == "php":
        composer_json = repo_path / "composer.json"
        if not composer_json.exists():
            return []

        commands: list[tuple[str, list[str]]] = []
        if not skip_install:
            commands.append(("Install", ["composer", "install", "--no-interaction", "--prefer-dist"]))

        artisan = repo_path / "artisan"
        phpunit = repo_path / "vendor" / "bin" / "phpunit"
        if artisan.exists():
            commands.append(("Tests", ["php", "artisan", "test"]))
        elif phpunit.exists():
            commands.append(("Tests", [str(phpunit)]))
        return [(label, wrap_repo_command_for_service(repo, repo_path, command)) for label, command in commands]

    if runner == "pnpm":
        package_json = repo_path / "package.json"
        if not package_json.exists():
            return []

        try:
            package = json.loads(package_json.read_text(encoding="utf-8"))
        except json.JSONDecodeError:
            return []

        scripts = package.get("scripts", {})
        if not isinstance(scripts, dict):
            scripts = {}

        commands = []
        if not skip_install:
            install_command = ["pnpm", "install", "--frozen-lockfile"] if (repo_path / "pnpm-lock.yaml").exists() else ["pnpm", "install"]
            commands.append(("Install", install_command))

        for script_name, label in [("lint", "Lint"), ("test", "Tests"), ("build", "Build")]:
            if script_name in scripts:
                commands.append((label, ["pnpm", script_name]))
        return [(label, wrap_repo_command_for_service(repo, repo_path, command)) for label, command in commands]

    if runner == "pytest":
        if shutil.which("pytest"):
            return [("Tests", wrap_repo_command_for_service(repo, repo_path, ["pytest"]))]

    if runner == "go":
        go_mod = repo_path / "go.mod"
        if go_mod.exists() and shutil.which("go"):
            commands: list[tuple[str, list[str]]] = []
            if not skip_install:
                commands.append(("Install", ["go", "mod", "download"]))
            commands.append(("Tests", ["go", "test", "./..."]))
            commands.append(("Build", ["go", "build", "./..."]))
            return [(label, wrap_repo_command_for_service(repo, repo_path, command)) for label, command in commands]

    return []


