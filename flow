def command_plan(args: argparse.Namespace) -> int:
    spec_path = resolve_spec(args.spec)
    slug = spec_slug(spec_path)
    if flow_memory_ops.memory_execution_enabled(
        args,
        workspace_config=WORKSPACE_CONFIG,
        arg_name="memory_recall",
        config_name="recall_before_plan",
    ):
        flow_memory_ops.write_plan_recall_report(
            root=ROOT,
            workspace_config=WORKSPACE_CONFIG,
            slug=slug,
            spec_path=spec_path,
            json_dumps=json_dumps,
        )

    def _callback() -> int:
        return flow_features.command_plan(
            args,
            require_dirs=require_dirs,
            resolve_spec=resolve_spec,
            spec_slug=spec_slug,
            analyze_spec=analyze_spec,
            require_routed_paths=require_routed_paths,
            repo_slice_prefix=repo_slice_prefix,
            repo_root=repo_root,
            worktree_root=WORKTREE_ROOT,
            plan_root=PLAN_ROOT,
            read_state=read_state,
            write_state=write_state,
            ensure_remote_claim_for_plan=lambda claim_slug: flow_gateway_ops.ensure_remote_claim_for_plan(
                root=ROOT,
                slug=claim_slug,
                read_state=read_state,
                workspace_config=WORKSPACE_CONFIG,
            ),
            rel=rel,
            utc_now=utc_now,
        )

    rc = flow_gateway_ops.run_with_remote_claim_heartbeat(
        root=ROOT,
        slug=slug,
        read_state=read_state,
        workspace_config=WORKSPACE_CONFIG,
        callback=_callback,
        reason="auto-heartbeat-plan",
    )
    if rc == 0:
        flow_gateway_ops.maybe_publish_transition_hook(
            root=ROOT,
            slug=slug,
            read_state=read_state,
            workspace_config=WORKSPACE_CONFIG,
            to_state="triaged",
            reason="hook-plan-succeeded",
        )
    return rc


